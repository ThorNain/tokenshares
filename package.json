{
  "name": "tokenshares-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Prototype de démonstration — tokens indexés sur des actions cotées. Aucun investissement réel.",
  "scripts": {
    "predev": "prisma db push --skip-generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "seed": "prisma db push --skip-generate && tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@prisma/client": "^5.19.1",
    "@privy-io/react-auth": "^1.69.0",
    "@privy-io/server-auth": "^1.7.0",
    "clsx": "^2.1.1",
    "jose": "^5.9.2",
    "next": "^14.2.5",
    "nextjs-toploader": "^3.9.17",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.2",
    "stripe": "^16.8.0",
    "tailwind-merge": "^2.5.2",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.46.1",
    "@types/node": "^20.16.1",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.41",
    "prisma": "^5.19.1",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
