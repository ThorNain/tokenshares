// ============================================================================
// Schéma de données — TokenShares (prototype de démonstration).
//
// Provider : PostgreSQL (Neon), utilisé en local ET en production pour éviter
// la dérive de schéma entre les deux environnements. Les statuts restent des
// String validés par Zod + unions TypeScript (src/lib/status.ts) et les
// montants des Float : ce schéma privilégie la simplicité et la compatibilité
// SQLite historique plutôt que les enums natifs/Decimal de
// prisma/schema.postgres.prisma (migration recommandée avant tout usage avec
// de l'argent réel — voir la checklist du README).
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooler transactionnel (Supabase/Supavisor, port 6543) : utilisé à
  // l'exécution par Prisma Client — compatible serverless (Vercel).
  url       = env("DATABASE_URL")
  // Pooler session (port 5432) : utilisé par `prisma db push`/`migrate` car
  // le mode transactionnel ne supporte pas les requêtes préparées des DDL.
  directUrl = env("DIRECT_URL")
}

// --- Utilisateurs & wallets --------------------------------------------------

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  firstName   String?
  lastName    String?
  // Identifiant Privy (did:privy:...) lorsque l'authentification Privy est active.
  privyUserId String?  @unique
  // "customer" | "admin" — voir src/lib/status.ts
  role        String   @default("customer")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wallets    Wallet[]
  orders     Order[]
  sellOrders SellOrder[]

  @@index([createdAt])
}

model Wallet {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Adresse publique uniquement. AUCUNE clé privée, AUCUNE seed phrase
  // n'est jamais stockée où que ce soit dans cette application.
  address String
  chainId Int    @default(84532)
  // "privy" | "demo"
  provider  String   @default("demo")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([address, chainId])
  @@index([userId])
}

// --- Catalogue ---------------------------------------------------------------

model Asset {
  id        String  @id @default(cuid())
  ticker    String  @unique
  name      String
  // "SP500" | "CAC40" | "NIKKEI225"
  indexName String
  country   String
  currency  String
  // Prix de base utilisé par le fournisseur de prix simulé.
  basePrice Float
  initials  String
  // Objet de collection (« totem ») expédié avec la commande : visuel emoji,
  // description et photo produit optionnelle (fichier sous /public, ex.
  // "/totems/aapl.webp" — priorité : photo > emoji > initiales).
  totemEmoji String?
  totemName  String?
  totemImage String?
  // Identifiant du token ERC-1155 associé à cet actif.
  tokenId   Int     @unique
  active    Boolean @default(true)
  // Marge spécifique (ex : 0.10). Null = marge globale (Setting margin_rate).
  marginRateOverride Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  prices        MarketPrice[]
  orderItems    OrderItem[]
  hedgingOrders HedgingOrder[]
  tokenMints    TokenMint[]
  sellOrders    SellOrder[]

  @@index([indexName])
  @@index([active])
}

// Instantanés de prix (historique + prix figé à la commande).
model MarketPrice {
  id       String   @id @default(cuid())
  assetId  String
  asset    Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  price    Float
  currency String
  // "mock" | nom du futur fournisseur de données
  source    String   @default("mock")
  asOf      DateTime
  createdAt DateTime @default(now())

  @@index([assetId, asOf])
}

// --- Commandes ---------------------------------------------------------------

model Order {
  id       String @id @default(cuid())
  // Identifiant public court, affiché au client (ex : ORD-8F3K2A).
  publicId String @unique
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  // created | pending_payment | paid | hedge_simulated | mint_pending |
  // minted | shipping_pending | shipped | delivered | failed | refunded |
  // cancelled — voir src/lib/status.ts
  status String @default("created")

  currency       String
  // Somme des (prix de marché figé × quantité).
  subtotalAmount Float
  marginRate     Float
  marginAmount   Float
  totalAmount    Float

  needsReview  Boolean   @default(false)
  internalNote String?
  paidAt       DateTime?
  refundedAt   DateTime?
  // Token transféré hors plateforme (détecté par l'indexeur on-chain) vers une
  // adresse qui n'appartient à aucun compte connu. La commande est alors
  // retirée du portefeuille du vendeur et le certificat l'indique. Si le
  // destinataire EST un compte connu, on réattribue plutôt `userId` (pas ce flag).
  transferredOffchain Boolean @default(false)
  transferredToAddress String?
  transferredAt        DateTime?

  // --- Cadeau (mint différé, réclamation par code) ---
  // Commande « cadeau » : l'action est achetée/couverte mais AUCUN token n'est
  // émis tant que le destinataire n'a pas saisi le code de réclamation. Le mint
  // se fait alors dans le wallet du destinataire.
  isGift             Boolean @default(false)
  // Code de réclamation (bearer, comme un code de carte cadeau). Null tant que
  // la couverture n'est pas exécutée.
  redeemCode         String?  @unique
  redeemedByUserId   String?
  redeemedAt         DateTime?
  // Acheteur d'origine (conservé après réattribution de userId au destinataire).
  giftPurchaserUserId String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  items           OrderItem[]
  shippingAddress ShippingAddress?
  payment         Payment?
  hedgingOrder    HedgingOrder?
  tokenMint       TokenMint?
  physicalItem    PhysicalItem?
  qrCodes         QrCode[]
  transactions    BlockchainTransaction[]
  auditLogs       AuditLog[]
  errorLogs       ErrorLog[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  quantity Int
  // Prix de marché indicatif figé au moment de la commande.
  lockedMarketPrice Float
  // Prix de vente unitaire = lockedMarketPrice × (1 + marginRate).
  unitSellingPrice Float
  marginAmount     Float
  currency         String
  priceLockedAt    DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([orderId])
  @@index([assetId])
}

model ShippingAddress {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  firstName  String
  lastName   String
  line1      String
  line2      String?
  postalCode String
  city       String
  country    String
  phone      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// --- Paiement ----------------------------------------------------------------

model Payment {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // "stripe" | "mock"
  provider String
  // pending | processing | succeeded | failed | refunded
  status String @default("pending")

  amount   Float
  currency String
  // Montant réellement encaissé (renseigné par le webhook).
  amountReceived Float?
  method         String?

  stripeSessionId       String? @unique
  stripePaymentIntentId String?
  // Le webhook signé a-t-il été vérifié avec succès ?
  webhookVerified Boolean @default(false)

  paidAt     DateTime?
  refundedAt DateTime?
  failureMessage String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([status])
}

// Journal des événements webhook reçus — clé d'idempotence anti double
// traitement (un même événement Stripe ne déclenche jamais deux émissions).
model WebhookEvent {
  id         String   @id @default(cuid())
  provider   String
  externalId String   @unique
  type       String
  orderId    String?
  processedAt DateTime @default(now())
  createdAt  DateTime @default(now())
}

// --- Couverture simulée (achat d'action chez un courtier) ---------------------

model HedgingOrder {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  ticker          String
  quantity        Int
  referencePrice  Float
  currency        String
  notionalAmount  Float
  // not_started | pending | processing | simulated_filled | failed | cancelled
  status String @default("not_started")
  // "mock-broker" | "manual" — remplacé plus tard par le courtier réglementé.
  provider  String  @default("mock-broker")
  brokerRef String?
  // Prix réel d'exécution saisi par l'opérateur (mode courtier manuel).
  executedPrice Float?
  attempts  Int     @default(0)
  lastError String?
  executedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([status])
}

// --- Ordre de vente (rachat de l'action + destruction du token) --------------
// Parcours symétrique à l'achat : le détenteur demande la revente, l'opérateur
// vend l'action réelle chez le courtier et saisit le prix obtenu, puis le token
// est détruit (burn) on-chain — il « disparaît » du wallet.
model SellOrder {
  id       String @id @default(cuid())
  publicId String @unique
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  assetId  String
  asset    Asset  @relation(fields: [assetId], references: [id])

  ticker        String
  quantity      Int
  // Adresse du wallet depuis lequel les tokens seront détruits.
  walletAddress String
  // Prix indicatif au moment de la demande.
  referencePrice Float
  currency       String
  // pending_broker | sold_pending_burn | burning | completed | failed | cancelled
  status String @default("pending_broker")

  provider  String  @default("mock-broker")
  brokerRef String?
  // Prix réel de vente saisi par l'opérateur + produit net correspondant.
  executedPrice  Float?
  proceedsAmount Float?
  executedAt     DateTime?

  // Transaction de destruction (burn) du token.
  burnTxHash        String?
  burnBlockNumber   Int?
  burnConfirmations Int     @default(0)
  burnFeeWei        String?

  // Clé d'idempotence du burn (garantit une seule destruction par ordre).
  idempotencyKey String @unique
  attempts       Int    @default(0)
  lastError      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([assetId])
  @@index([status])
}

// --- Émission du token -------------------------------------------------------

model TokenMint {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  tokenId         Int
  contractAddress String
  network         String
  quantity        Int
  // Wallet public de destination (wallet Privy de l'utilisateur).
  toAddress String
  // not_started | queued | minting | mint_submitted | mint_confirmed |
  // transfer_pending | transfer_submitted | transfer_confirmed | failed | cancelled
  status String @default("not_started")

  txHash        String?
  blockNumber   Int?
  confirmations Int     @default(0)
  feeWei        String?
  attempts      Int     @default(0)
  lastError     String?
  submittedAt   DateTime?
  confirmedAt   DateTime?
  // Clé d'idempotence dérivée de l'identifiant de commande : garantit
  // qu'un même paiement ne provoque jamais deux émissions.
  idempotencyKey String @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  transactions BlockchainTransaction[]

  @@index([status])
}

model BlockchainTransaction {
  id          String     @id @default(cuid())
  orderId     String?
  order       Order?     @relation(fields: [orderId], references: [id])
  tokenMintId String?
  tokenMint   TokenMint? @relation(fields: [tokenMintId], references: [id])

  // "mint" | "transfer"
  type        String
  network     String
  fromAddress String
  toAddress   String
  tokenId     Int?
  quantity    Int?
  txHash      String? @unique
  blockNumber Int?
  // pending | submitted | confirmed | failed
  status        String @default("pending")
  confirmations Int    @default(0)
  feeWei        String?
  error         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  confirmedAt   DateTime?

  @@index([status])
  @@index([orderId])
}

// --- Indexation on-chain ------------------------------------------------------

// Événement de transfert ERC-1155 observé sur la blockchain (indexeur). Sert à
// réconcilier la propriété applicative avec la vérité on-chain quand un token
// est transféré HORS de la plateforme (Coinbase Wallet, MetaMask…).
model ChainTransfer {
  id          String @id @default(cuid())
  network     String
  txHash      String
  logIndex    Int
  blockNumber Int
  // "mint" (from = 0x0) | "burn" (to = 0x0) | "transfer" (entre deux adresses)
  kind        String
  fromAddress String
  toAddress   String
  tokenId     Int
  amount      Int
  // Réconciliation effectuée (propriété applicative mise à jour) ?
  processed   Boolean   @default(false)
  processedAt DateTime?
  note        String?
  createdAt   DateTime  @default(now())

  // Un même événement (tx + index de log + token) n'est indexé qu'une fois.
  // Le tokenId est inclus car un log TransferBatch porte plusieurs tokens.
  @@unique([txHash, logIndex, tokenId])
  @@index([kind, processed])
  @@index([fromAddress])
  @@index([toAddress])
}

// --- Objet physique & QR code -------------------------------------------------

model PhysicalItem {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // "miniature_car" pour le MVP.
  kind String @default("miniature_car")
  // not_started | preparing | ready | shipped | delivered
  status              String    @default("not_started")
  carrier             String?
  trackingNumber      String?
  shippedAt           DateTime?
  estimatedDeliveryAt DateTime?
  deliveredAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model QrCode {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Code public court (URL /p/{publicToken}, ex. AB7X92). Ne contient JAMAIS de
  // clé privée, seed phrase, mot de passe, session ni donnée personnelle.
  publicToken String    @unique
  active      Boolean   @default(true)
  revokedAt   DateTime?
  // Suivi des scans (analytics) : nombre de consultations de la page /p/{code}.
  scanCount     Int       @default(0)
  lastScannedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([orderId])
}

// --- Journalisation ------------------------------------------------------------

model AuditLog {
  id String @id @default(cuid())
  // "user" | "admin" | "system"
  actorType  String
  actorId    String?
  actorEmail String?
  action     String
  entityType String
  entityId   String
  orderId    String?
  order      Order?  @relation(fields: [orderId], references: [id])
  oldValue   String?
  newValue   String?
  justification String?
  createdAt  DateTime @default(now())

  @@index([orderId])
  @@index([action])
  @@index([createdAt])
}

model ErrorLog {
  id String @id @default(cuid())
  // "privy" | "stripe" | "database" | "market-data" | "broker" | "mint" |
  // "blockchain" | "qrcode" | "shipping"
  service String
  type    String
  // info | warning | error | critical
  severity         String  @default("error")
  message          String
  technicalMessage String?
  orderId          String?
  order            Order?  @relation(fields: [orderId], references: [id])
  userId           String?
  attempts         Int     @default(0)
  lastAttemptAt    DateTime?
  nextAttemptAt    DateTime?
  resolved         Boolean   @default(false)
  resolvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([service])
  @@index([severity])
  @@index([resolved])
}

// --- Paramètres globaux ---------------------------------------------------------

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
