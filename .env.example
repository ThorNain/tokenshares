# ============================================================================
# TokenShares — Prototype de démonstration. AUCUN investissement réel.
# Copiez ce fichier vers .env puis ajustez. Les valeurs par défaut permettent
# de lancer l'application 100 % en local (mocks), sans aucun compte externe.
# ============================================================================

# --- Base de données ---------------------------------------------------------
# SQLite par défaut (zéro configuration). Pour PostgreSQL (Neon/Supabase),
# voir prisma/schema.postgres.prisma et le README.
DATABASE_URL="file:./dev.db"

# --- Application -------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Secret de signature des sessions (JWT). Générez une valeur aléatoire longue
# en production : `openssl rand -hex 32`.
SESSION_SECRET="dev-only-secret-change-me-4f8a2c1e9b7d6035"

# --- Mode démonstration ------------------------------------------------------
# Active les boutons de simulation manuelle dans l'admin (section 28 du cahier
# des charges). DOIT être "false" (ou absent) en production.
DEMO_MODE="true"
NEXT_PUBLIC_DEMO_MODE="true"

# --- Compte administrateur de démonstration ----------------------------------
# Créé/validé côté serveur uniquement. Jamais exposé au frontend.
ADMIN_EMAIL="admin@example.test"
ADMIN_PASSWORD="demo-admin-2026!"

# --- Privy (authentification + embedded wallet) — OPTIONNEL ------------------
# Sans ces valeurs, l'application utilise le mode "connexion de démonstration"
# (email seul, wallet fictif) clairement identifié dans l'interface.
# Créez une app sur https://dashboard.privy.io (login methods : email, passkey).
NEXT_PUBLIC_PRIVY_APP_ID=""
PRIVY_APP_SECRET=""

# --- Stripe (paiement) — OPTIONNEL, MODE TEST UNIQUEMENT ----------------------
# Sans ces valeurs, un fournisseur de paiement simulé est utilisé (page de
# paiement fictive avec succès/échec). Utilisez EXCLUSIVEMENT des clés de test
# (préfixe sk_test_ / pk_test_).
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Secret de signature du webhook (stripe listen --forward-to localhost:3000/api/webhooks/stripe)
STRIPE_WEBHOOK_SECRET=""

# --- Données de marché ---------------------------------------------------------
# "mock"  : prix simulés déterministes (défaut, aucune dépendance réseau).
# "yahoo" : cours différés Yahoo Finance (endpoint public NON officiel — prototype
#           uniquement, pas de licence de redistribution). Repli automatique sur
#           la simulation si Yahoo est injoignable.
MARKET_DATA_PROVIDER="mock"

# --- Conversion des prix vers l'euro -----------------------------------------
# Taux fixes du prototype : valeur de 1 unité de devise source en EUR.
# À remplacer par un fournisseur FX horodaté avant toute utilisation réelle.
NEXT_PUBLIC_FX_USD_EUR_RATE="0.92"
NEXT_PUBLIC_FX_JPY_EUR_RATE="0.0061"

# --- Blockchain (testnet EVM) -------------------------------------------------
# "mock"  : blockchain simulée en base (par défaut, aucune configuration).
# "viem"  : vraie chaîne de test (Base Sepolia recommandé) — nécessite RPC_URL,
#           TOKEN_CONTRACT_ADDRESS et MINTER_PRIVATE_KEY.
BLOCKCHAIN_PROVIDER="mock"
RPC_URL=""
CHAIN_ID="84532"
TOKEN_CONTRACT_ADDRESS=""
# Clé du wallet "minter" (testnet UNIQUEMENT — jamais une clé détenant des
# fonds réels ; ce n'est PAS une clé d'utilisateur).
MINTER_PRIVATE_KEY=""
NEXT_PUBLIC_BLOCK_EXPLORER_URL="https://sepolia.basescan.org"
NEXT_PUBLIC_CHAIN_NAME="Base Sepolia"

# --- Simulation d'échecs (tests) ----------------------------------------------
# Tickers (séparés par des virgules) dont le mint échouera volontairement,
# pour tester la gestion d'erreurs et la relance manuelle. Ex : "NVDA,7203.T"
DEMO_FAIL_MINT_TICKERS=""
